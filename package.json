{
  "name": "vite-plugin-vue-middleware",
  "version": "0.1.1",
  "description": "File-based navigation guards for Vue Router",
  "keywords": [
    "middleware",
    "router",
    "typescript",
    "vite",
    "vite-plugin",
    "vue",
    "vue-router"
  ],
  "homepage": "https://github.com/awdr74100/vite-plugin-vue-middleware#readme",
  "bugs": {
    "url": "https://github.com/awdr74100/vite-plugin-vue-middleware/issues"
  },
  "license": "MIT",
  "author": "Roya <a78945612385238@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awdr74100/vite-plugin-vue-middleware.git"
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "types": {
        "import": "./dist/runtime.d.mts",
        "require": "./dist/runtime.d.cts"
      },
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.cjs"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "knip": "knip",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pathe": "^2.0.3",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "bumpp": "^11.0.1",
    "knip": "^6.3.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vue-router": "^5.0.4"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vue-router": ">=4.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
